# --- Steps 1, 2, 4: Azure AI Language Service ---
# Get these from Azure Portal: Language resource → Keys and Endpoint
# Format: https://<resource-name>.cognitiveservices.azure.com/
AZURE_AI_LANGUAGE_ENDPOINT="https://your-resource-name.cognitiveservices.azure.com/"
# Use Key 1 or Key 2 (either works)
AZURE_AI_LANGUAGE_KEY="paste-your-language-key-here"

# --- Step 3: Azure Translator Service ---
# IMPORTANT: Translator uses a DIFFERENT key than Language service!
# Get from Azure Portal: Translator resource → Keys and Endpoint
AZURE_TRANSLATOR_KEY="paste-your-translator-key-here"
# Must match your Translator resource region (eastus, westeurope, etc)
AZURE_TRANSLATOR_REGION=eastus

# --- Step 4 (optional): CLU Model Configuration ---
# Only needed if instructor has deployed the CLU model
# Project name must match exactly what's in Azure portal
CLU_PROJECT_NAME=your-clu-project
# Deployment name (usually "production" or "main")
CLU_DEPLOYMENT_NAME=your-deployment
